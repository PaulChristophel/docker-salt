{
  "image": "docker.io/pcm0/salt",
  "platform": "linux/amd64",
  "requirements": {
    "directory": "requirements",
    "common": "common.txt"
  },
  "python": [
    {
      "version": "3.11",
      "debian_release": "3.11-slim",
      "requirements": "python/3.11.txt"
    },
    {
      "version": "3.12",
      "debian_release": "3.12-slim",
      "requirements": "python/3.12.txt"
    },
    {
      "version": "3.13",
      "debian_release": "3.13-slim",
      "requirements": "python/3.13.txt"
    },
    {
      "version": "3.14",
      "debian_release": "3.14-slim",
      "requirements": "python/3.14.txt"
    }
  ],
  "salt": [
    {
      "name": "3006",
      "version": "3006.25",
      "requirement": "salt==3006.25",
      "channel": "stable"
    },
    {
      "name": "3008",
      "version": "3008.2",
      "requirement": "salt==3008.2",
      "channel": "stable"
    },
    {
      "name": "3006.x",
      "requirement": "git+https://github.com/saltstack/salt.git@3006.x",
      "channel": "development"
    },
    {
      "name": "3008.x",
      "requirement": "git+https://github.com/saltstack/salt.git@3008.x",
      "channel": "development"
    },
    {
      "name": "master",
      "requirement": "git+https://github.com/saltstack/salt.git",
      "channel": "development"
    }
  ],
  "profiles": [
    {
      "name": "standard",
      "requirements": "profiles/standard.txt",
      "tag_suffix": ""
    },
    {
      "name": "isalt",
      "requirements": "profiles/isalt.txt",
      "tag_suffix": "-isalt"
    }
  ],
  "variants": [
    {
      "name": "debian",
      "dockerfile": "Python-debian.dockerfile",
      "python": ["3.11", "3.12", "3.13", "3.14"],
      "salt": ["3006", "3008", "3006.x", "3008.x", "master"]
    },
    {
      "name": "photon5",
      "tag": "photon",
      "dockerfile": "Python-photon.dockerfile",
      "python": ["3.14"],
      "salt": ["3008", "3008.x", "master"]
    }
  ]
}
